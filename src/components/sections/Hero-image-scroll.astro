---
import { Image } from "astro:assets";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<section class="hero-scroll">
  <div class="hero-scroll__inner grid">
    <div class="hero-scroll__item">
      <h1 class="hero-scroll__heading heading-medium">
        {title}
      </h1>
    </div>
    <div class="hero-scroll__item">
      <div class="hero-scroll__image-wrapper">
        <img src="/public/assets/images/hero-scroll/slide-photo-1.jpg" alt="" />
      </div>
    </div>
    <div class="hero-scroll__item">
      <div class="hero-scroll__image-wrapper">
        <img src="" alt="" />
      </div>
    </div>
  </div>
</section>

<style>
  .hero-scroll {
    --height-value: 54px;

    padding-top: var(--height-value);
    padding-inline: var(--spacing-4);
    height: 100vh;
  }

  .hero-scroll__inner {
    height: 100%;
  }

  .hero-scroll__heading {
    max-width: 370px;
  }

  .hero-scroll__item {
    grid-column: span 4;

    &:first-child {
      padding-bottom: var(--spacing-8);
      align-self: end;
    }
  }

  .hero-scroll__image-wrapper {
    height: 100%;

    img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
  }
</style>
